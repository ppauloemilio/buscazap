# Banco PostgreSQL no Neon — confira com: SELECT current_database();
# Pooler (runtime na Vercel) — host com "-pooler" e pgbouncer=true
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/buscazap?sslmode=require&pgbouncer=true"
# Conexão direta (migrations) — host sem "-pooler"
DIRECT_URL="postgresql://user:password@host.neon.tech/buscazap?sslmode=require"

# URL pública do app (webhooks PIX)
APP_URL="https://buscazap-livid.vercel.app"

# PIX — desenvolvimento (código estático + botão simular)
PIX_PROVIDER="static"
PIX_ENABLE_SIMULATE="true"
PIX_WEBHOOK_SECRET="change-me-in-production"

# PIX — produção com Mercado Pago
# PIX_PROVIDER="mercadopago"
# PIX_ENABLE_SIMULATE="false"
# MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
# MERCADOPAGO_TEST_PAYER_EMAIL="test_user_123456@testuser.com"
# PIX_WEBHOOK_SECRET="chave-forte-para-webhook-interno"

# Upload de fotos dos anúncios (Vercel Blob — obrigatório em produção)
# Crie um Blob Store no painel da Vercel e vincule ao projeto.
# A Vercel adiciona BLOB_STORE_ID (OIDC) e, opcionalmente, BLOB_READ_WRITE_TOKEN.
# Use "private" para stores privados (padrao) ou "public" para stores publicos.
# BLOB_ACCESS="private"
# BLOB_STORE_ID="store_..."
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
