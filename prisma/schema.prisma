generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Provider {
  id                    String          @id @default(cuid())
  name                  String
  email                 String          @unique
  whatsapp              String
  passwordHash          String
  role                  String          @default("PROVIDER")
  status                String          @default("ACTIVE")
  age                   Int?
  state                 String?
  city                  String?
  neighborhood          String?
  bio                   String?
  subscriptionExpiresAt DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  advertisements        Advertisement[]
  payments              Payment[]
  subscriptions         Subscription[]
  auditLogs             AuditLog[]
  passwordResetTokens   PasswordResetToken[]
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([providerId, createdAt])
}

model Advertisement {
  id               String         @id @default(cuid())
  providerId       String
  provider         Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title            String
  description      String
  type             String
  status           String         @default("APPROVED")
  category         String
  isCustomCategory Boolean        @default(false)
  city             String
  state            String
  neighborhood     String?
  whatsappNumber   String
  rating           Float          @default(0)
  reviewCount      Int            @default(0)
  premiumExpiresAt DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  premiumBoosts    PremiumBoost[]
  images           AdvertisementImage[]
}

model AdvertisementImage {
  id              String        @id @default(cuid())
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  url             String
  kind            String        @default("GALLERY")
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([advertisementId, kind])
}

model Subscription {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  amount     Float
  startsAt   DateTime
  expiresAt  DateTime
  paymentId  String   @unique
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model PremiumBoost {
  id              String        @id @default(cuid())
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  providerId      String
  amount          Float
  startsAt        DateTime
  expiresAt       DateTime
  paymentId       String        @unique
  payment         Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

model Payment {
  id           String        @id @default(cuid())
  providerId   String
  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  type         String
  amount       Float
  status       String        @default("PENDING")
  pixTxId      String        @unique
  pixCopyPaste String
  referenceId  String?
  paidAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  subscription Subscription?
  premiumBoost PremiumBoost?
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      Provider @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model Report {
  id               String   @id @default(cuid())
  advertisementRef String
  reason           String
  details          String?
  status           String   @default("OPEN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CatalogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String   @default("Tag")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategorySuggestion {
  id             String   @id @default(cuid())
  name           String
  normalizedKey  String   @unique
  status         String   @default("PENDING")
  mergedIntoName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CatalogState {
  id        String       @id @default(cuid())
  uf        String       @unique @db.VarChar(2)
  name      String       @unique
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  cities    CatalogCity[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model CatalogCity {
  id        String       @id @default(cuid())
  name      String
  stateId   String
  state     CatalogState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, stateId])
}
