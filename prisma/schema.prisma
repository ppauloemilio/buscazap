generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Provider {
  id                    String          @id @default(cuid())
  name                  String
  email                 String?         @unique
  whatsapp              String          @unique
  passwordHash          String
  role                  String          @default("PROVIDER")
  status                String          @default("ACTIVE")
  age                   Int?
  state                 String?
  city                  String?
  neighborhood          String?
  bio                   String?
  businessHours         String?
  responseHint          String?
  referralCode          String          @unique
  freePremiumCredits    Int             @default(0)
  referredById          String?
  referredBy            Provider?       @relation("ProviderReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals             Provider[]      @relation("ProviderReferrals")
  subscriptionExpiresAt DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  advertisements        Advertisement[]
  payments              Payment[]
  subscriptions         Subscription[]
  auditLogs             AuditLog[]
  passwordResetTokens   PasswordResetToken[]
  referralsMade         Referral[]      @relation("ReferralsMade")
  referralReceived      Referral?       @relation("ReferralReceived")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  providerId String
  provider   Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([providerId, createdAt])
}

model Advertisement {
  id               String         @id @default(cuid())
  providerId       String
  provider         Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  title            String
  description      String
  type             String
  status           String         @default("APPROVED")
  category         String
  isCustomCategory Boolean        @default(false)
  city             String
  state            String
  neighborhood     String?
  serviceArea      String         @default("CITY_WIDE")
  whatsappNumber   String
  rating           Float          @default(0)
  reviewCount      Int            @default(0)
  premiumExpiresAt DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  premiumBoosts    PremiumBoost[]
  images           AdvertisementImage[]
  reviews          Review[]
}

model Review {
  id              String        @id @default(cuid())
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  authorName      String
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())

  @@index([advertisementId])
}

model AdvertisementImage {
  id              String        @id @default(cuid())
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  url             String
  kind            String        @default("GALLERY")
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([advertisementId, kind])
}

model Subscription {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  amount     Float
  startsAt   DateTime
  expiresAt  DateTime
  paymentId  String   @unique
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model PremiumBoost {
  id              String        @id @default(cuid())
  advertisementId String
  advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)
  providerId      String
  amount          Float         @default(0)
  source          String        @default("PAID")
  startsAt        DateTime
  expiresAt       DateTime
  paymentId       String?       @unique
  payment         Payment?      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referrer   Provider @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId String   @unique
  referred   Provider @relation("ReferralReceived", fields: [referredId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([referrerId, createdAt])
}

model Payment {
  id           String        @id @default(cuid())
  providerId   String
  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  type         String
  amount       Float
  status       String        @default("PENDING")
  pixTxId      String        @unique
  pixCopyPaste String
  referenceId  String?
  paidAt       DateTime?
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  subscription Subscription?
  premiumBoost PremiumBoost?
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      Provider @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model Report {
  id               String   @id @default(cuid())
  advertisementRef String
  reason           String
  details          String?
  status           String   @default("OPEN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CatalogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String   @default("🏷️")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategorySuggestion {
  id             String   @id @default(cuid())
  name           String
  normalizedKey  String   @unique
  status         String   @default("PENDING")
  mergedIntoName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CatalogState {
  id        String       @id @default(cuid())
  uf        String       @unique @db.VarChar(2)
  name      String       @unique
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  cities    CatalogCity[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model CatalogCity {
  id        String       @id @default(cuid())
  name      String
  stateId   String
  state     CatalogState @relation(fields: [stateId], references: [id], onDelete: Cascade)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, stateId])
}

model HomepageSetting {
  id                    String   @id @default("default")
  showUrgentSearches    Boolean  @default(false)
  showPopularCategories Boolean  @default(false)
  showCityExplorer      Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}

model ProviderLead {
  id           String   @id @default(cuid())
  name         String
  whatsapp     String
  city         String
  state        String   @default("PA")
  neighborhood String
  serviceArea  String
  adTitle      String
  photoUrl     String?
  status       String   @default("NEW")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
  @@index([whatsapp, createdAt])
}
